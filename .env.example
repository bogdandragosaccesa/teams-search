# Copy to .env and adjust. NEVER commit the real .env.
# All values here are safe DEV defaults — override for any internet-exposed host.

# SearXNG
BASE_URL=http://localhost:8082/
# REQUIRED for production: a long random string, e.g. `openssl rand -hex 32`
SEARXNG_SECRET_KEY=teamssearch-dev-secret
# Rate limiting: 0 = off (dev), 1 = on (production/shared)
RATE_LIMIT=0
# Bot-detection bypass: true (dev) / false (production)
BYPASS_BLOCKLIST=true

# API auth (empty = open; set a value to require Bearer token)
SEARCH_API_KEY=
SCRAPER_API_KEY=
